{
  "name": "@adaptivelink/pops",
  "version": "0.6.1",
  "description": "Points of Presence geolocation",
  "keywords": [
    "alibaba",
    "arubacloud",
    "atlanticnet",
    "aws",
    "azurecdn",
    "backblaze",
    "bunnycdn",
    "cachefly",
    "cdn",
    "cdn77",
    "cloudflare",
    "cloudfront",
    "cloudsigma",
    "deno",
    "digitalocean",
    "equinix",
    "fastly",
    "flexential",
    "google",
    "heroku",
    "hetzner",
    "hivelocity",
    "hostwinds",
    "imperva",
    "ionos",
    "kamatera",
    "keycdn",
    "leapswitch",
    "lightsail",
    "limelight",
    "linode",
    "mnx",
    "netlify",
    "ovh",
    "scaleway",
    "stackpath",
    "sucuri",
    "upcloud",
    "vercel",
    "verizonmedia",
    "vultr",
    "wasabi"
  ],
  "homepage": "https://github.com/adaptive/pops#readme",
  "bugs": {
    "url": "https://github.com/adaptive/pops/issues"
  },
  "license": "MIT",
  "author": "Hugo Romano <adaptive@hey.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adaptive/pops.git"
  },
  "type": "module",
  "main": "dist/bundle.js",
  "types": "main.d.ts",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "bun build ./src/main.js --outfile ./dist/bundle.js --minify --target browser --format esm",
    "prebuild": "oxfmt --write '**/*.{js,json}'",
    "iata": "bun ./tools/iata-filter.js > ./data/iata-filtered-test.js && mv ./data/iata-filtered-test.js ./data/iata-filtered.js",
    "validate": "bun ./tools/validator.js",
    "test": "bun test ./test",
    "csv": "bun ./tools/csv-generator.js > ./notebooks/data.csv",
    "providers:list": "bun ./tools/providers/list.js",
    "provider:maintain": "bun ./tools/providers/maintain-provider.js",
    "provider:show": "bun ./tools/providers/show-provider.js",
    "provider:update": "bun ./tools/providers/update-provider.js"
  },
  "devDependencies": {
    "@adaptivelink/iata": "0.1.6"
  },
  "packageManager": "bun@1.3.11"
}
